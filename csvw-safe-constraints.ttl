@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix csvw: <http://www.w3.org/ns/csvw#> .
@prefix cs: <http://example.org/csvw-safe#> .

############################################
# Table
############################################

cs:TableShape
    a sh:NodeShape ;
    sh:targetClass csvw:Table ;

    sh:property [
        sh:path cs:privacyUnit ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path cs:maxContributions ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path cs:maxLength ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path cs:length ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] .

############################################
# Column
############################################

cs:ColumnShape
    a sh:NodeShape ;
    sh:targetClass csvw:Column ;

    sh:property [
        sh:path csvw:name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path csvw:datatype ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path csvw:required ;
        sh:datatype xsd:boolean ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path cs:privacyId ;
        sh:datatype xsd:boolean ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path cs:nullableProportion ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
    ] .

############################################
# Dependency
############################################

cs:DependencyShape
    a sh:NodeShape ;

    sh:property [
        sh:path cs:dependsOn ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path cs:dependencyType ;
        sh:datatype xsd:string ;
        sh:in ("mapping" "bigger" "fixedPerEntity") ;
        sh:minCount 1 ;
    ] .

############################################
# Partition
############################################

cs:PartitionShape
    a sh:NodeShape ;

    sh:property [
        sh:path cs:maxLength ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path cs:maxGroupsPerUnit ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path cs:maxContributions ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] .

############################################
# Predicate (categorical)
############################################

cs:CategoricalPredicateShape
    a sh:NodeShape ;

    sh:property [
        sh:path cs:partitionValue ;
        sh:minCount 1 ;
    ] .

############################################
# Predicate (continuous)
############################################

cs:ContinuousPredicateShape
    a sh:NodeShape ;

    sh:property [
        sh:path cs:lowerBound ;
    ] ;

    sh:property [
        sh:path cs:upperBound ;
    ] .
