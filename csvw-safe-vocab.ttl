@prefix csvw-safe: <https://w3id.org/csvw-safe#> .
@prefix csvw:      <http://www.w3.org/ns/csvw#> .
@prefix rdf:       <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:       <http://www.w3.org/2002/07/owl#> .
@prefix xsd:       <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:   <http://purl.org/dc/terms/> .


# =====================================================
# Ontology
# =====================================================

csvw-safe:
    a owl:Ontology ;
    dct:title "CSVW Differential Privacy Extension Vocabulary" ;
    owl:versionInfo "0.3.0" ;
    owl:versionIRI <https://w3id.org/csvw-dp/0.3.0> ;
    dct:description """
    A vocabulary extending W3C CSV on the Web metadata for expressing
    safe structural and differential privacy modeling assumptions.
    """ ;
    dct:creator <https://github.com/dscc-admin-ch> ;
    dct:publisher <https://github.com/dscc-admin-ch> ;
    dct:created "2026-02-04"^^xsd:date ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:imports <http://www.w3.org/ns/csvw> ;
    rdfs:seeAlso <https://github.com/dscc-admin-ch/csvw-dp> .


################################################################################
# Core Classes
################################################################################

csvw-safe:GroupingKey a owl:Class ;
    rdfs:label "Grouping Key" ;
    rdfs:comment "Represents a multi-column grouping space." .

csvw-safe:ColumnGroup a owl:Class ;
    rdfs:subClassOf csvw-safe:GroupingKey ;
    rdfs:label "Column Group" ;
    rdfs:comment "Grouping key composed of multiple columns." .

csvw-safe:Partition a owl:Class ;
    rdfs:label "Partition" ;
    rdfs:comment "A publicly defined region of the value domain." .

csvw-safe:Contribution a owl:Class ;
    rdfs:label "Contribution" ;
    rdfs:comment "Contribution bounds relative to a specific privacy unit." .

################################################################################
# Privacy Model
################################################################################

csvw-safe:privacyModel a owl:ObjectProperty ;
    rdfs:domain csvw:Table ;
    rdfs:range csvw-safe:PrivacyModel ;
    rdfs:label "privacy model" .

csvw-safe:PrivacyModel a owl:Class .

csvw-safe:independent a csvw-safe:PrivacyModel .
csvw-safe:hierarchical a csvw-safe:PrivacyModel .
csvw-safe:joint a csvw-safe:PrivacyModel .

################################################################################
# Public Invariant Properties
################################################################################

csvw-safe:public.privacyUnit a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (csvw:Table csvw-safe:Contribution)
    ] ;
    rdfs:range xsd:string ;
    rdfs:label "privacy unit identifier" .

csvw-safe:public.privacyId a owl:DatatypeProperty ;
    rdfs:domain csvw:Column ;
    rdfs:range xsd:boolean .

csvw-safe:public.length a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (csvw:Table csvw-safe:Partition)
    ] ;
    rdfs:range xsd:nonNegativeInteger .

csvw-safe:public.maxNumPartitions a owl:DatatypeProperty ;
    rdfs:domain csvw-safe:GroupingKey ;
    rdfs:range xsd:nonNegativeInteger .

csvw-safe:public.partitions a owl:ObjectProperty ;
    rdfs:domain csvw-safe:GroupingKey ;
    rdfs:range csvw-safe:Partition .

csvw-safe:public.exhaustivePartitions a owl:DatatypeProperty ;
    rdfs:domain csvw-safe:GroupingKey ;
    rdfs:range xsd:boolean .

################################################################################
# Contribution Bounds (Privacy Guarantees)
################################################################################

csvw-safe:bounds.maxContributions a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (csvw:Table csvw-safe:Partition csvw-safe:Contribution)
    ] ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "l_infinity bound: max rows per privacy unit per region." .

csvw-safe:bounds.maxLength a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (csvw:Table csvw-safe:Partition)
    ] ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Maximum theoretical number of rows." .

csvw-safe:bounds.maxGroupsPerUnit a owl:DatatypeProperty ;
    rdfs:domain csvw-safe:GroupingKey ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "l_0 bound: max partitions affected per privacy unit." .

################################################################################
# Preprocessing Recommendations
################################################################################

csvw-safe:rec.maxContributions a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (csvw:Table csvw-safe:Partition csvw-safe:Contribution)
    ] ;
    rdfs:range xsd:nonNegativeInteger .

csvw-safe:rec.maxGroupsPerUnit a owl:DatatypeProperty ;
    rdfs:domain csvw-safe:GroupingKey ;
    rdfs:range xsd:nonNegativeInteger .

################################################################################
# Contribution Wrapper
################################################################################

csvw-safe:contributions a owl:ObjectProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (csvw:Table csvw-safe:Partition csvw-safe:GroupingKey)
    ] ;
    rdfs:range csvw-safe:Contribution .

################################################################################
# Partition Predicate Model
################################################################################

csvw-safe:predicate a owl:ObjectProperty ;
    rdfs:domain csvw-safe:Partition ;
    rdfs:range csvw-safe:Predicate .

csvw-safe:Predicate a owl:Class .

csvw-safe:partitionValue a owl:DatatypeProperty ;
    rdfs:domain csvw-safe:Predicate ;
    rdfs:range xsd:string .

csvw-safe:lowerBound a owl:DatatypeProperty ;
    rdfs:domain csvw-safe:Predicate ;
    rdfs:range xsd:decimal .

csvw-safe:upperBound a owl:DatatypeProperty ;
    rdfs:domain csvw-safe:Predicate ;
    rdfs:range xsd:decimal .

csvw-safe:lowerInclusive a owl:DatatypeProperty ;
    rdfs:domain csvw-safe:Predicate ;
    rdfs:range xsd:boolean .

csvw-safe:upperInclusive a owl:DatatypeProperty ;
    rdfs:domain csvw-safe:Predicate ;
    rdfs:range xsd:boolean .

csvw-safe:components a owl:ObjectProperty ;
    rdfs:domain csvw-safe:Predicate ;
    rdfs:range rdf:Property ;
    rdfs:comment "Map column name to component predicate (JSON-LD object form)." .

################################################################################
# Structural Modeling (Synthetic Hints)
################################################################################

csvw-safe:synth.nullableProportion a owl:DatatypeProperty ;
    rdfs:domain csvw:Column ;
    rdfs:range xsd:decimal .

csvw-safe:synth.dependsOn a owl:ObjectProperty ;
    rdfs:domain csvw:Column ;
    rdfs:range csvw:Column .

csvw-safe:synth.how a owl:DatatypeProperty ;
    rdfs:domain csvw:Column ;
    rdfs:range xsd:string .

csvw-safe:synth.mapping a owl:ObjectProperty ;
    rdfs:domain csvw:Column .
